<div>
	<fieldset>
		<div class="form-group">
			<label>{{localize "QUICK_DICE.DiceCreator.Formula.name"}}</label>
			<div class="form-fields">
				<input type="text" name="dice.key" value="{{dice.key}}" required />
			</div>
			<p class="hint">{{localize "QUICK_DICE.DiceCreator.Formula.hint"}}</p>
		</div>
		<div class="form-group">
			<label>{{localize "QUICK_DICE.DiceCreator.Row.name"}}</label>
			<div class="form-fields">
				<input
					type="number"
					name="row"
					value="{{value}}"
					min="1"
					max="{{maxRows}}"
					steps="1"
					required
					{{ifThen (eq value maxRows) "readonly" ""}}
				/>
			</div>
			<p class="hint">{{localize "QUICK_DICE.DiceCreator.Row.hint"}}</p>
		</div>
		<div class="form-group">
			<label>{{localize "QUICK_DICE.DiceCreator.Image.name"}}</label>
			<div class="form-fields">
				<file-picker name="dice.img" value="{{dice.img}}" data-type="image" data-target="img"></file-picker>
			</div>
		</div>
	</fieldset>
	<fieldset>
		<legend>{{localize "QUICK_DICE.Optional"}}</legend>
		<div class="form-group">
			<label>{{localize "QUICK_DICE.DiceCreator.Label.name"}}</label>
			<div class="form-fields">
				<input type="text" name="dice.label" value="{{dice.label}}" placeholder="{{dice.key}}" />
			</div>
			<p class="hint">{{localize "QUICK_DICE.DiceCreator.Label.hint"}}</p>
		</div>
		<div class="form-group">
			<label>{{localize "QUICK_DICE.DiceCreator.Tooltip.name"}}</label>
			<div class="form-fields">
				<input type="text" name="dice.tooltip" value="{{dice.tooltip}}" placeholder="{{dice.key}}"/>
			</div>
			<p class="hint">{{localize "QUICK_DICE.DiceCreator.Tooltip.hint"}}</p>
		</div>
		<div class="form-group">
			<label>{{localize "QUICK_DICE.DiceCreator.Color.name"}}</label>
			<div class="form-fields">
				<color-picker name="dice.color" value="{{dice.color}}"></color-picker>
			</div>
			<p class="hint">{{localize "QUICK_DICE.DiceCreator.Color.hint"}}</p>
		</div>
	</fieldset>
	{{#if dice.key}}
	<fieldset>
		<legend>{{localize "QUICK_DICE.DiceCreator.Preview"}}</legend>
		<div class="quick-dice" style="pointer-events: none;">
			<div class="quick-dice__buttons flexrow" style="height: 30px;">
				{{> "modules/quickdice/templates/partials/tray-button.hbs"
					data=dice
					key=dice.key
					buttonStyle="width: 40px; position: relative;"
					diceStyle="height: 100%; aspect-ratio: 1/1;"
					labelStyle="padding-right: 0.25rem;"
				}}
			</div>
		</div>
	</fieldset>
	{{/if}}
</div>
